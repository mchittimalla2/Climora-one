APP_NAME=Climoraone
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
CLIMORAONE_STORE_URL=https://dev.climoraone.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=climoraone
DB_USERNAME=climoraone_app
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=security@climoraone.com
MAIL_FROM_NAME="${APP_NAME}"

BREVO_API_KEY=
BREVO_FROM_EMAIL=info@climoraone.com
BREVO_FROM_NAME=Climoraone
ADMIN_NOTIFICATION_EMAIL=

# Razorpay test-mode credentials. Never commit real values.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

# Admin accounts are created only when both email and password are supplied.
# Never commit real credentials. Set these values only in the server's .env file.
ADMIN_OWNER_NAME="Climoraone Owner"
ADMIN_OWNER_EMAIL=
ADMIN_OWNER_PASSWORD=

ADMIN_EDITOR_NAME="Climoraone Admin"
ADMIN_EDITOR_EMAIL=
ADMIN_EDITOR_PASSWORD=

# Emergency recovery only. Use a unique mailbox and an offline-stored password.
ADMIN_BREAK_GLASS_NAME="Climoraone Emergency Access"
ADMIN_BREAK_GLASS_EMAIL=
ADMIN_BREAK_GLASS_PASSWORD=

ADMIN_OTP_TTL_MINUTES=5
ADMIN_OTP_MAX_ATTEMPTS=5
ADMIN_SESSION_IDLE_MINUTES=30
ADMIN_SESSION_ABSOLUTE_HOURS=8

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
